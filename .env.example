## Local backend defaults.
## Copy to .env.local when running backend directly on the host.
TRACE_DB_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/trace_test
TRACE_REDIS_URL=redis://127.0.0.1:6379/0
TRACE_API_HOST=127.0.0.1
TRACE_API_PORT=8000

## LLM defaults.
## Docker Compose automatically reads .env from the repo root.
## Keep the default as MockLLM for deterministic demos and smoke tests.
TRACE_LLM_PROVIDER=mock
TRACE_LLM_MODEL=mock-1
TRACE_LLM_API_KEY=
TRACE_LLM_BASE_URL=

## Optional LLM tuning.
# TRACE_LLM_TEMPERATURE=0.2
# TRACE_LLM_MAX_OUTPUT_TOKENS=4096
# TRACE_LLM_REASONING_EFFORT=medium

## Real LLM examples.
## Docker Compose reads real values from .env.
## Local backend runs can also use backend/llm.config.json or shell env vars.
## Do not commit secrets.
#
## OpenAI Responses API:
# TRACE_LLM_PROVIDER=openai
# TRACE_LLM_MODEL=gpt-5
# TRACE_LLM_API_KEY=sk-...
# TRACE_LLM_BASE_URL=https://api.openai.com/v1
#
## OpenAI-compatible chat completions endpoint:
# TRACE_LLM_PROVIDER=openai_chat_compat
# TRACE_LLM_MODEL=your-model
# TRACE_LLM_API_KEY=your-api-key
# TRACE_LLM_BASE_URL=https://example.com/v1
